# CSE 468 - Project 1
# Server VM Setup Commands

# Check available network interfaces
ip addr show

# Assign static IP address to the server interface
sudo ip addr add 10.0.0.10/8 dev enp0s3
sudo ip link set enp0s3 up

# Add default gateway (points to Gateway VM's server-side interface)
sudo ip route add default via 10.0.0.100

# Verify IP and routing configuration
ip addr show
ip route

# Open the netplan config file and paste the contents from server-netcfg.yaml
sudo nano /etc/netplan/01-netcfg.yaml

# After saving the file, apply the configuration
sudo netplan apply

# Verify connectivity (run after Gateway is fully configured)
ping 10.0.0.100       
ping google.com     
